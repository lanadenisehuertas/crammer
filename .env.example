# Copy to .env and fill in. .env is gitignored.

# --- AI provider: pick ONE -------------------------------------------------
# Option A: Claude (paid, needs Anthropic credits)
ANTHROPIC_API_KEY=sk-ant-your-key-here
# Option B: Gemini (free tier — get a key at aistudio.google.com)
GEMINI_API_KEY=

# Optional: force which provider to use instead of auto-detecting from the
# keys above. Valid values: claude, gemini.
# REVIEWER_PROVIDER=gemini

# Where the local SQLite database lives. Defaults to ./reviewer.sqlite3 if unset.
REVIEWER_DB_PATH=reviewer.sqlite3

# Which Claude model to use (only relevant when provider=claude).
# Defaults to claude-opus-4-7. For lower cost, use claude-sonnet-4-6 or
# claude-haiku-4-5.
REVIEWER_MODEL=claude-opus-4-7

# Which Gemini model to use (only relevant when provider=gemini).
# Defaults to gemini-2.5-flash.
REVIEWER_GEMINI_MODEL=gemini-2.5-flash
